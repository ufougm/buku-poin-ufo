# ============================================
# Buku Poin UFO UGM - Supabase Configuration
# ============================================
#
# 1. Create a Supabase project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy Project URL and anon/public key
# 4. Add these to your Vercel project:
#    - Go to Vercel Dashboard > your project > Settings > Environment Variables
#    - Add VITE_SUPABASE_URL = your-project-url
#    - Add VITE_SUPABASE_ANON_KEY = your-anon-key
# 5. Run the SQL in supabase-schema.sql in Supabase SQL Editor
# 6. Redeploy on Vercel

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
