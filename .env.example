# ==========================================
# BUKU POIN UFO UGM - Environment Variables
# ==========================================

# --- Supabase (Database + Auth + Storage) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (used by Drizzle ORM) ---
# This is your Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# --- Auth (Session Secret) ---
SESSION_SECRET=generate-a-random-secret-key-at-least-32-characters

# --- Frontend ---
VITE_API_URL=/api

# (Optional) Kimi OAuth - not used in Vercel/Supabase deployment
# VITE_KIMI_AUTH_URL=...
# VITE_APP_ID=...
